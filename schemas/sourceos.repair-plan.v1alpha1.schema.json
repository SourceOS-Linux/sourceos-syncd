{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sourceos.dev/schemas/sourceos.repair-plan.v1alpha1.schema.json",
  "title": "SourceOS Repair Plan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "generated_at",
    "source_report",
    "plan_id",
    "status",
    "severity",
    "summary",
    "policy",
    "preconditions",
    "checkpoint",
    "steps",
    "blocked_steps",
    "rollback",
    "postconditions"
  ],
  "properties": {
    "schema": { "const": "sourceos.repair-plan/v1alpha1" },
    "generated_at": { "type": "string", "format": "date-time" },
    "source_report": {
      "type": "object",
      "additionalProperties": true,
      "required": ["schema", "component"],
      "properties": {
        "schema": { "type": ["string", "null"] },
        "component": { "type": ["string", "null"] },
        "generated_at": { "type": ["string", "null"], "format": "date-time" }
      }
    },
    "plan_id": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "enum": ["preview", "approved", "running", "complete", "failed", "rolled_back"] },
    "severity": { "type": "string", "enum": ["info", "warning", "error", "critical"] },
    "summary": { "type": "string", "minLength": 1 },
    "policy": {
      "type": "object",
      "additionalProperties": true,
      "required": ["engine", "required_grants", "destructive_grants_required", "destructive_actions_present"],
      "properties": {
        "engine": { "type": "string", "minLength": 1 },
        "required_grants": { "type": "array", "items": { "type": "string" } },
        "destructive_grants_required": { "type": "array", "items": { "type": "string" } },
        "destructive_actions_present": { "type": "boolean" }
      }
    },
    "preconditions": {
      "type": "array",
      "items": { "$ref": "#/$defs/check" }
    },
    "checkpoint": {
      "type": "object",
      "additionalProperties": true,
      "required": ["required", "type"],
      "properties": {
        "required": { "type": "boolean" },
        "type": { "type": "string", "minLength": 1 },
        "write_audit_record": { "type": "boolean" }
      }
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/step" }
    },
    "blocked_steps": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["id", "reason"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "reason": { "type": "string", "minLength": 1 }
        }
      }
    },
    "rollback": {
      "type": "object",
      "additionalProperties": true,
      "required": ["available", "strategy", "requires_operator_approval"],
      "properties": {
        "available": { "type": "boolean" },
        "strategy": { "type": "string", "minLength": 1 },
        "requires_operator_approval": { "type": "boolean" }
      }
    },
    "postconditions": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "$defs": {
    "check": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "status", "check"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "status": { "type": "string", "minLength": 1 },
        "check": { "type": "string", "minLength": 1 }
      }
    },
    "step": {
      "type": "object",
      "additionalProperties": true,
      "required": ["order", "id", "kind", "destructive", "description", "expected_result"],
      "properties": {
        "order": { "type": "integer", "minimum": 1 },
        "id": { "type": "string", "minLength": 1 },
        "kind": { "type": "string", "minLength": 1 },
        "destructive": { "type": "boolean" },
        "description": { "type": "string", "minLength": 1 },
        "expected_result": { "type": "string", "minLength": 1 }
      }
    }
  }
}
