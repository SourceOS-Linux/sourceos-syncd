{
  "schema": "sourceos.schema-record/v1alpha1",
  "schema_id": "schema:source-object:v1",
  "object_type": "source_object",
  "schema_version": "v1",
  "required_fields": ["object_id", "object_type", "profile_id", "workspace_id"],
  "field_owners": {
    "object_id": "sourceos-syncd",
