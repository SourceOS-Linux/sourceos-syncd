#!/usr/bin/env bash
set -euo pipefail

echo "sourceos-syncd credential surface"
echo "expected secrets: none currently declared"
echo "redaction: required"

echo
echo "configured credential paths:"
for p in "$HOME/.config/sourceos-syncd" "$HOME/.local/state/sourceos-syncd"; do
  if [ -e "$p" ]; then
    echo "  exists: $p"
    find "$p" -maxdepth 2 -type f 2>/dev/null | sed 's#^#    file: #' | sed -E 's/(token|key|secret|password|auth)/<redacted-name>/Ig'
  else
    echo "  missing: $p"
  fi
done

echo
echo "policy: do not print secret values; declare any future token/key/OAuth/SecretRef storage in TRUST_SURFACE.yaml"
